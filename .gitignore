# --- Secrets & Environment ---
.env
*.env.local
*.env.*.local

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
.mypy_cache/
.ruff_cache/
.pytest_cache/
.coverage
htmlcov/
venv/
.venv/
env/
pip-wheel-metadata/

# --- SQLite Database ---
*.db
*.sqlite
*.sqlite3

# --- Node / Frontend ---
frontend/node_modules/
frontend/.vite/
frontend/dist/
frontend/build/
frontend/.eslintcache
frontend/coverage/
*.tsbuildinfo

# --- Logs ---
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- Docker ---
.docker/

# --- OS ---
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# --- IDE ---
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# --- BPF build artifacts ---
*.ll
*.bc
*.bpf.o
